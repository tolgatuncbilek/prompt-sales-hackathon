HOST=0.0.0.0
PORT=3000
NODE_ENV=development
# DATABASE_URL=postgres://crm:crm_dev@localhost:5432/hmd_crm
SESSION_SECRET=change-me-session-secret

# Dedicated Hermes/OpenClaw CRM AI Gateway
OPENCLAW_URL=http://your-openclaw-gateway:8787/v1/chat/completions
OPENCLAW_KEY=your-openclaw-key
ASSISTANT_MODEL=hermes-crm

# DeepSeek API (optional, used for local AI features)
DEEPSEEK_API=sk-your-deepseek-api-key

# Email Integration (Webhooks / IMAP Fallback)
EMAIL_WEBHOOK_SECRET=change-me
EMAIL_WEBHOOK_ENABLED=true
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=crm@example.com
EMAIL_IMAP_PASS=change-me
