{
  "name": "prompt-sales-hackathon",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "preview": "astro preview --host 0.0.0.0",
    "start": "bun ./dist/server/entry.mjs",
    "db:start": "docker compose up -d db",
    "db:migrate": "bun src/db/migrate.ts",
    "db:seed": "bun src/db/seed.ts",
    "db:setup": "bun run db:start && sleep 3 && bun run db:migrate && bun run db:seed"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@astrojs/node": "^10.1.1",
    "@astrojs/react": "^5.0.5",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.7",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
