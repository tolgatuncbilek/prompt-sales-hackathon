---
import App from "../components/App";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="HMD Secure CRM hackathon project starter."
    />
    <title>HMD Secure CRM</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <App client:load />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
      "Segoe UI", sans-serif;
    color: #eef2f7;
    background: #0b0d11;
    font-synthesis: none;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-width: 320px;
    min-height: 100vh;
    background:
      radial-gradient(circle at 75% 0%, rgba(74, 129, 214, 0.12), transparent 32rem),
      #0b0d11;
  }

  button,
  a {
    font: inherit;
  }

  button {
    color: inherit;
  }

  button:focus-visible,
  a:focus-visible {
    outline: 2px solid #6da9ff;
    outline-offset: 3px;
  }

  .app-shell {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 15rem minmax(0, 1fr);
  }

  .sidebar {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1rem;
    border-right: 1px solid #20242c;
    background: rgba(12, 15, 20, 0.92);
  }

  .brand,
  .profile {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .brand {
    color: inherit;
    text-decoration: none;
    padding: 0.25rem;
  }

  .brand-mark,
  .avatar {
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.65rem;
    background: #6da9ff;
    color: #08111f;
    font-weight: 800;
  }

  .brand strong,
  .brand small,
  .profile strong,
  .profile small {
    display: block;
  }

  .brand strong,
  .profile strong {
    font-size: 0.875rem;
  }

  .brand small,
  .profile small {
    margin-top: 0.15rem;
    color: #818896;
    font-size: 0.75rem;
  }

  nav {
    display: grid;
    gap: 0.25rem;
    margin-top: 2.5rem;
  }

  .nav-item {
    width: 100%;
    padding: 0.7rem 0.75rem;
    border: 0;
    border-radius: 0.55rem;
    background: transparent;
    color: #929aa8;
    text-align: left;
    cursor: pointer;
    transition:
      color 160ms ease,
      background 160ms ease;
  }

  .nav-item:hover,
  .nav-item.active {
    color: #f4f7fb;
    background: #191d24;
  }

  .profile {
    margin-top: auto;
    padding: 0.75rem 0.25rem 0;
    border-top: 1px solid #20242c;
  }

  .avatar {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: #242a34;
    color: #b7c9e5;
    font-size: 0.7rem;
  }

  .workspace {
    min-width: 0;
    padding: clamp(1.5rem, 4vw, 4rem);
  }

  .workspace-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2rem;
    max-width: 74rem;
    margin: 0 auto;
    padding-bottom: 2rem;
    border-bottom: 1px solid #242832;
  }

  .eyebrow {
    margin: 0 0 0.65rem;
    color: #6da9ff;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  h1,
  h2,
  p {
    margin-top: 0;
  }

  h1 {
    margin-bottom: 0.55rem;
    font-size: clamp(2rem, 4vw, 3rem);
    letter-spacing: -0.04em;
  }

  h2 {
    margin-bottom: 0.75rem;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    letter-spacing: -0.035em;
  }

  .workspace-header p:not(.eyebrow),
  .empty-state > p:last-child {
    max-width: 36rem;
    margin-bottom: 0;
    color: #929aa8;
    line-height: 1.65;
  }

  .primary-action {
    flex: 0 0 auto;
    min-height: 2.75rem;
    padding: 0.7rem 1rem;
    border: 0;
    border-radius: 0.6rem;
    background: #6da9ff;
    color: #08111f;
    font-weight: 750;
    cursor: pointer;
    transition:
      transform 160ms ease,
      background 160ms ease;
  }

  .primary-action:hover {
    transform: translateY(-1px);
    background: #8dbbff;
  }

  .empty-state {
    max-width: 74rem;
    min-height: 55vh;
    margin: 0 auto;
    display: grid;
    align-content: center;
    justify-items: start;
  }

  .status-dot {
    width: 0.75rem;
    height: 0.75rem;
    margin-bottom: 1.25rem;
    border-radius: 50%;
    background: #64d49b;
    box-shadow: 0 0 0 0.35rem rgba(100, 212, 155, 0.1);
  }

  @media (max-width: 720px) {
    .app-shell {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      height: auto;
      padding: 1rem;
      border-right: 0;
      border-bottom: 1px solid #20242c;
    }

    nav {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      margin-top: 1rem;
      overflow-x: auto;
    }

    .nav-item {
      text-align: center;
      white-space: nowrap;
    }

    .profile {
      display: none;
    }

    .workspace-header {
      display: grid;
    }

    .primary-action {
      width: 100%;
    }
  }
</style>
